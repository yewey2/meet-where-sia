# Optional browser key for arbitrary addresses, postal codes, Google place
# autocomplete, reverse geocoding, and Google map rendering. Without it, the
# OpenStreetMap map, exact MRT/LRT station names, and Singapore coordinates work.
# Restrict it by HTTP referrer and to Maps JavaScript API, Places API (New),
# and Geocoding API in Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=

# Optional custom Google Cloud map ID. DEMO_MAP_ID is used when omitted.
VITE_GOOGLE_MAP_ID=

# Server-only LTA DataMall AccountKey. Never prefix this with VITE_.
LTA_ACCOUNT_KEY=

PORT=8787
